{
  "id": "staff-credential",
  "name": "Izylife Staff Credential Presentation",
  "purpose": "Requesting proof that the holder is an authorised Izylife operator.",
  "format": {
    "ldp_vp": {
      "proof_type": [
        "Ed25519Signature2018",
        "EdDSA"
      ]
    }
  },
  "submission_requirements": [
    {
      "name": "Provide a staff credential",
      "rule": "all",
      "from": "staff"
    }
  ],
  "input_descriptors": [
    {
      "id": "staff",
      "name": "Public Authority Staff ID",
      "purpose": "Validate that the presenter is part of the Izylife public authority staff.",
      "group": [
        "staff"
      ],
      "constraints": {
        "fields": [
          {
            "path": [
              "$.type"
            ],
            "filter": {
              "type": "array",
              "contains": {
                "const": "PublicAuthorityStaffCredential"
              }
            }
          },
          {
            "path": [
              "$.credentialSubject.role"
            ],
            "filter": {
              "type": "string",
              "minLength": 1
            }
          },
          {
            "path": [
              "$.credentialSubject.employeeNumber"
            ],
            "filter": {
              "type": "string",
              "minLength": 1
            }
          }
        ]
      }
    }
  ]
}
