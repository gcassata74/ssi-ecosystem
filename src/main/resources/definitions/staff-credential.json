{
  "id": "staff-credential",
  "name": "Credenziale personale Izylife",
  "purpose": "Stai per inviare le seguenti informazioni per attestare l'appartenenza al personale Izylife.",
  "format": {
    "ldp_vp": {
      "proof_type": [
        "Ed25519Signature2018",
        "EdDSA"
      ]
    }
  },
  "submission_requirements": [
    {
      "name": "Provide a staff credential",
      "rule": "all",
      "from": "staff"
    }
  ],
  "input_descriptors": [
    {
      "id": "staff",
      "name": "Dati anagrafici personale Izylife",
      "purpose": "Servono per verificare l'identità del personale prima dell'emissione della credenziale.",
      "group": [
        "staff"
      ],
      "constraints": {
        "fields": [
          {
            "path": [
              "$.type"
            ],
            "filter": {
              "type": "array",
              "contains": {
                "const": "PublicAuthorityStaffCredential"
              }
            }
          },
          {
            "path": [
              "$.credentialSubject.fiscalNumber"
            ],
            "purpose": "Codice fiscale del personale (es. TINIT-LVLDAA85T50G702B).",
            "filter": {
              "type": "string",
              "minLength": 1
            }
          },
          {
            "path": [
              "$.credentialSubject.name"
            ],
            "purpose": "Nome del personale (es. Ada).",
            "filter": {
              "type": "string",
              "minLength": 1
            }
          },
          {
            "path": [
              "$.credentialSubject.familyName"
            ],
            "purpose": "Cognome del personale (es. Lovelace).",
            "filter": {
              "type": "string",
              "minLength": 1
            }
          },
          {
            "path": [
              "$.credentialSubject.email"
            ],
            "purpose": "Email istituzionale (es. aabyron@hotmail.com).",
            "filter": {
              "type": "string",
              "format": "email"
            }
          }
        ]
      }
    }
  ]
}
