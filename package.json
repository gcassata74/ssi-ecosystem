{
  "name": "@izylife/ssi-auth-client",
  "version": "0.1.4",
  "description": "Client library to integrate SSI issuer/verifier authentication into JavaScript and Angular apps.",
  "keywords": [
    "ssi",
    "did",
    "oauth2",
    "oidc",
    "angular",
    "authentication"
  ],
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./angular": {
      "types": "./dist/angular/index.d.ts",
      "import": "./dist/angular/index.js",
      "require": "./dist/angular/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsup",
    "lint": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "funding": {
    "type": "individual",
    "url": "https://example.com/support"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/ssi-client-lib.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/ssi-client-lib/issues"
  },
  "author": "",
  "devDependencies": {
    "@types/node": "^20.11.30",
    "rimraf": "^5.0.5",
    "tsup": "^7.2.0",
    "typescript": "^5.4.5",
    "@angular/core": "^20.0.0",
    "@angular/common": "^20.0.0",
    "@angular/platform-browser": "^20.0.0",
    "rxjs": "^7.8.1"
  },
  "peerDependencies": {
    "@angular/common": ">=16 <21",
    "@angular/core": ">=16 <21",
    "rxjs": ">=7.8.0 <8"
  },
  "peerDependenciesMeta": {
    "@angular/common": {
      "optional": true
    },
    "@angular/core": {
      "optional": true
    },
    "rxjs": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  }
}
